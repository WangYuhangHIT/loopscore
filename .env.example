# Copy this file to `.env` (already gitignored) and fill in your key.
# server.js reads it on startup; it never overrides a variable already exported
# in your shell. The key is written with 0600 perms and is never committed.
#
# You can also set the key from the in-app gear (LLM settings) panel instead of
# editing this file by hand — it writes here for you.
#
# Optional: LoopScore runs fully on its deterministic metrics WITHOUT any key.
# A key only enables the bucket-2 LLM judge, the manager note, and ambiguous-role
# re-checks. Point the provider at any Anthropic-compatible endpoint in
# loopscore.config.json (or via the gear panel).

LOOPSCORE_JUDGE_KEY=
